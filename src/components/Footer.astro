---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-logo">E<span>▶</span>ITINI</div>
  <p>© {year} EDITINI Digital Marketing Agency. Tous droits réservés.</p>
  <div class="footer-tag">Digital Marketing Agency</div>
</footer>

<style>
  footer {
    padding: 48px 60px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--dark2);
  }

  .footer-logo {
    font-family: var(--font-bebas);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    color: var(--white);
  }

  .footer-logo span {
    color: var(--gold);
  }

  footer p {
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.3);
    letter-spacing: 0.05em;
  }

  .footer-tag {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(201, 147, 58, 0.5);
  }

  @media (max-width: 900px) {
    footer {
      flex-direction: column;
      gap: 16px;
      text-align: center;
      padding: 48px 24px;
    }
  }
</style>
